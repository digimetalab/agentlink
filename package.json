{
  "name": "agentlink",
  "version": "0.1.0",
  "description": "Universal MCP config sync for AI coding agents — Claude Code, Gemini CLI, OpenCode, Codex",
  "author": "digimetalab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/digimetalab/agentlink"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "gemini-cli",
    "opencode",
    "codex",
    "ai-agent",
    "vibe-coding",
    "model-context-protocol"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "agentlink": "bin/agentlink.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "ora": "^5.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
